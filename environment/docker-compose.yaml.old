services:
  # The main ETL process
  
  main:                         
      build:                   
        context: ${CONTEXT_DIR}
      image: ${MAIN_IMAGE_NAME}
      command: ["sh", "-c", "sleep infinity"]  
      environment:                            
        - TEST_DIR=${TEST_DIR}               
      volumes:                              
        - ${HOST_VERIFIER_LOGS_PATH}:${ENV_VERIFIER_LOGS_PATH}    
        - ${HOST_AGENT_LOGS_PATH}:${ENV_AGENT_LOGS_PATH}         
      deploy:                                                  
        resources:                                            
          limits:                                            
            cpus: ${CPUS}                                  
            memory: ${MEMORY}                          
      networks:                                  
        - app-network                         
  etl:
    build: ${CONTEXT_DIR}
    image: ${MAIN_IMAGE_NAME}
    volumes:
      - ${HOST_VERIFIER_LOGS_PATH}:${ENV_VERIFIER_LOGS_PATH} 
      - ${HOST_AGENT_LOGS_PATH}:${ENV_AGENT_LOGS_PATH}
    networks: 
      - app-network
    command: 
      - bash 
      - -c 
      - >-
        python3 weather_data.py --start 2024-01-01 --end 2024-12-31 && 
        touch /app/output/weather_data.db
    healthcheck:
      test: ["CMD", "test", "-f", "/app/output/weather_data.db"]  
      interval: 5s
      retries: 20
      start_period: 30s

  # The Visualization process
  viz:
    image: ${MAIN_IMAGE_NAME}
    volumes:
      - ${HOST_VERIFIER_LOGS_PATH}:${ENV_VERIFIER_LOGS_PATH}
      - ${HOST_AGENT_LOGS_PATH}:${ENV_AGENT_LOGS_PATH}
    entrypoint: python3
    command: ["visualize.py"]
    depends_on:
      etl:
        condition: service_healthy
    networks:
      - app-network
networks: 
    app-network: 
      driver: bridge  
